{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=meetmind;Username=postgres;Password=postgres"
  },
  "Frontend": {
    "Url": "http://localhost:5173"
  },
  "JWT": {
    "Secret": "your-super-secret-key-min-32-characters-long",
    "Issuer": "MeetMind",
    "Audience": "MeetMindUsers",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Storage": {
    "Provider": "LocalDisk",
    "LocalDiskPath": "uploads"
  }
}
